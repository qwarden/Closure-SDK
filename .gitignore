# Ignore everything, allowlist what ships
*

# CI
!.github/
!.github/workflows/
!.github/workflows/test.yml
!.github/workflows/publish.yml
!.github/FUNDING.yml

# Documentation
!.gitignore
!README.md
!LICENSE
!CLOSURE_SDK.md
!CLOSURE_CLI.md
!CLOSURE_DNA.md
!CLOSURE_APPLICATIONS.md
!TEST_RESULTS.md

# Root build config
!pyproject.toml

# Paper
!zeroth_law_full-1.pdf

# ─── Rust core (shared primitives) ───────────────────────────────────
!rust/
!rust/Cargo.toml
!rust/Cargo.lock
!rust/pyproject.toml
!rust/src/
!rust/src/**

# ─── closure_rs (compiled extension) ────────────────────────────────
!closure_rs/
!closure_rs/__init__.py

# ─── closure_sdk (verification SDK) ─────────────────────────────────
!closure_sdk/
!closure_sdk/__init__.py
!closure_sdk/ops.py
!closure_sdk/lenses.py
!closure_sdk/state.py
!closure_sdk/canon.py
!closure_sdk/valence.py
!closure_sdk/hopf.py
!closure_sdk/py.typed
!closure_sdk/tests/
!closure_sdk/tests/**

# ─── closure_cli (command-line interface) ────────────────────────────
!closure_cli/
!closure_cli/__init__.py
!closure_cli/__main__.py
!closure_cli/formatter.py
!closure_cli/identity.py
!closure_cli/observer.py
!closure_cli/reader.py
!closure_cli/seeker.py

# ─── closure_ea (computer umbrella: docs + src + demos) ─────────────
!closure_ea/
!closure_ea/README.md
!closure_ea/__init__.py
!closure_ea/__main__.py
!closure_ea/Cargo.toml
!closure_ea/Cargo.lock
!closure_ea/docs/
!closure_ea/docs/**
!closure_ea/src/
!closure_ea/src/**
!closure_ea/demos/
!closure_ea/demos/**
!closure_ea/archive/
!closure_ea/archive/**
closure_ea/**/__pycache__/
closure_ea/target/
closure_ea/target/**

# ─── closure_dna (standalone database package) ──────────────────────
!closure_dna/
!closure_dna/**
closure_dna/demo/databases/
closure_dna/demo/databases/**
!closure_dna/demo/databases/.gitkeep
closure_dna/**/__pycache__/
closure_dna/demo/databases/**/*.lock

# ─── Tests (root-level SDK tests) ───────────────────────────────────
!tests/
!tests/__init__.py
!tests/conftest.py

# ─── Examples ────────────────────────────────────────────────────────
!examples/
!examples/01_detect_drift.py
!examples/02_find_incidents.py
!examples/03_stream_classify.py
